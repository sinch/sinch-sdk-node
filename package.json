{
  "name": "sinch-sdk-node",
  "private": true,
  "version": "0.0.0",
  "description": "Sinch server SDK for Node.js. Check the README to know which APIs are supported",
  "repository": "git://github.com/sinch/sinch-sdk-node-monorepo.git",
  "author": "Sinch",
  "license": "Apache 2.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "lerna": "lerna",
    "bootstrap": "npx lerna bootstrap",
    "build": "lerna run build",
    "lint": "eslint \"packages/**/{src,tests}/**/*.ts\" \"examples/**/{src,}/**/*.{js,ts}\"",
    "test": "jest",
    "e2e": "lerna run test:e2e",
    "docs:api": "yarn build && cd docs/api && npm run build"
  },
  "keywords": [],
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-typescript": "^7.24.7",
    "@cucumber/cucumber": "^11.1.1",
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.5.13",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-jest-extended": "^3.0.1",
    "eslint-plugin-jest-formatting": "^3.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "lerna": "^7.4.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "typescript-eslint": "~8.55.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "resolutions": {
    "@typescript-eslint/utils": "8.55.0",
    "@typescript-eslint/scope-manager": "8.55.0",
    "@typescript-eslint/typescript-estree": "8.55.0",
    "@typescript-eslint/visitor-keys": "8.55.0",
    "@typescript-eslint/types": "8.55.0",
    "@typescript-eslint/project-service": "8.55.0",
    "@typescript-eslint/tsconfig-utils": "8.55.0"
  }
}

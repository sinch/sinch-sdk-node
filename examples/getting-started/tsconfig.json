{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "strictNullChecks": false,
    "target": "es2020",
    "module": "es2020",
    "moduleResolution": "node",
    "pretty": true,
    "baseUrl": ".",
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "**/*.js"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules"
  ]
}
